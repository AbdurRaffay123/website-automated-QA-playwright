{
  "name": "site-tester",
  "version": "1.0.0",
  "description": "Config-driven smoke/regression tester for web apps - checks pages, buttons, and all 4 API methods (GET/POST/PUT/DELETE)",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test api-tests",
    "test:ui": "playwright test ui-tests",
    "test:project": "node core/run.js",
    "cleanup": "node core/cleanupCli.js",
    "report": "playwright show-report reports/html"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  }
}
